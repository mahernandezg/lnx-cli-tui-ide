# Copy to config.env and fill in. config.env is gitignored, never committed.
#
# Used by modules/60-ssh-alias.sh to write an ~/.ssh/config alias and configure
# the kitty ssh kitten. No key material goes here — only the path to a private
# key that already exists locally on this machine.
#
# If config.env does not exist, the SSH module is skipped entirely.

SSH_ALIAS="myhost"
SSH_HOSTNAME="host.example.com"
SSH_USER="myuser"
SSH_IDENTITY="$HOME/.ssh/id_ed25519"
