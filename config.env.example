# Copy to config.env and fill in. config.env is gitignored, never committed.
#
# Used by modules/60-ssh-alias.sh to write an ~/.ssh/config alias and configure
# the kitty ssh kitten. No key material goes here — only the path to a private
# key that already exists locally on this machine.
#
# If config.env does not exist, the SSH module is skipped entirely.

# Required: the remote facts (these cannot be auto-detected).
SSH_ALIAS="myhost"
SSH_HOSTNAME="host.example.com"
SSH_USER="myuser"

# Optional: path to the private key. If left unset/commented, the installer
# auto-detects one from ~/.ssh, preferring id_ed25519 > id_ecdsa > id_rsa, then
# any private key it finds (matched by its key header, so deploy keys count too).
#SSH_IDENTITY="$HOME/.ssh/id_ed25519"

# Optional: extra non-standard key filenames to try FIRST during auto-detection
# (space-separated, looked up in ~/.ssh). Handy for deploy keys, e.g.:
#SSH_IDENTITY_CANDIDATES="id_deploy work_key"
