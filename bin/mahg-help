#!/usr/bin/env bash
# bin/mahg-help — one-glance cheatsheet of the Professor's terminal environment.
#
# Prints, in mahg brand colours, what is installed/configured RIGHT NOW: AI coding
# agents, CLI/TUI tools, key tmux shortcuts, Nautilus templates, and the config map.
# Principle: DYNAMIC over hardcoded — presence and versions are detected at runtime
# (command -v + --version); only the curated cheatsheet text (shortcuts, brand
# decisions) is static, and it is flagged to stay in sync with the real configs.
#
# Output modes (the default ANSI mode is unchanged):
#   (default)        ANSI cheatsheet for a terminal.
#   --format md      plain MARKDOWN (no ANSI) so a renderer (e.g. tmahg/glamour) styles it.
#   --list tools     parseable: one "<bin><TAB><class>" per PRESENT tool, class ∈ {tui,util}
#                    (tui = launches usefully with no args → menu/recipe; util = needs args).
#   --list agents    same, for the AI agents.
#
# Vendored in the repo and symlinked to ~/.local/bin/mahg-help by modules/95-mahg-help.sh.
set -uo pipefail

MAHG_HELP_VERSION="0.1.0"
EXTRAS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/mahg-help/tools"

# Curated tool registry: "label|bin[,altbins]|class".  class ∈ {tui, util}.
#   tui  = opens a useful UI with no args (goes to the tmahg menu/recipe generator)
#   util = a command-line utility that needs args / doesn't "open" (NOT in the menu)
_TOOLS=(
  "micro|micro|tui"           "vim|vim|tui"               "yazi|yazi|tui"
  "lazygit|lazygit|tui"       "lazydocker|lazydocker|tui" "euporie|euporie|util"
  "starship|starship|util"    "tmux|tmux|tui"             "uv|uv|util"
  "ripgrep|rg|util"           "bat|bat,batcat|util"       "fd|fd,fdfind|util"
  "htop|htop|tui"             "top|top|tui"               "btop|btop|tui"
  "bottom|btm,bottom|tui"     "glances|glances|tui"       "ncdu|ncdu|util"
  "gdu|gdu|util"              "dust|dust|util"            "duf|duf|util"
  "procs|procs|util"          "gping|gping|util"          "dog|dog|util"
  "bandwhich|bandwhich|util"  "tig|tig|tui"               "gitui|gitui|tui"
  "fzf|fzf|util"              "zoxide|zoxide|util"        "delta|delta|util"
  "eza|eza,exa|util"          "zellij|zellij|tui"         "nnn|nnn|tui"
  "ranger|ranger|tui"         "mc|mc|tui"                 "jq|jq|util"
  "glow|glow|util"            "hyperfine|hyperfine|util"
)
_AGENTS="pi codex claude agy grok copilot"

# ---- Args -------------------------------------------------------------------
use_color=1
section="all"
fmt="ansi"
list=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-color) use_color=0 ;;
    --format)
      fmt="${2:-}"; shift
      [[ "$fmt" == md || "$fmt" == ansi ]] || { printf 'mahg-help: --format must be md|ansi\n' >&2; exit 2; } ;;
    --list)
      list="${2:-tools}"; shift
      [[ "$list" == tools || "$list" == agents ]] || { printf 'mahg-help: --list must be tools|agents\n' >&2; exit 2; } ;;
    -V|--version) printf 'mahg-help %s\n' "$MAHG_HELP_VERSION"; exit 0 ;;
    -h|--help)
      printf 'Usage: mahg-help [section] [--format md] [--no-color]\n'
      printf '       mahg-help --list tools|agents\n'
      printf '  sections: all (default) | agents | tools | shortcuts | templates | paths\n'
      printf '  --format md   emit plain markdown (no ANSI) for a renderer to style\n'
      printf '  --list tools  parseable "<bin>\\t<class>" per present tool (class: tui|util)\n'
      printf '  --version     print version\n'
      printf '\nExtra tools: add lines to %s\n' "$EXTRAS_FILE"
      printf '  one per line: "label bin [altbins...] [:tui|:util]"  (or just "bin").\n'
      printf '  They show in the tools section; the :class (default util) sets --list class.\n'
      exit 0 ;;
    agents|tools|shortcuts|templates|paths|all) section="$1" ;;
    *) printf 'mahg-help: unknown argument: %s (try -h)\n' "$1" >&2; exit 2 ;;
  esac
  shift
done
# Markdown is plain text (no colour). Colour also off when piped / NO_COLOR / --no-color.
[[ "$fmt" == md ]] && use_color=0
[[ -n "${NO_COLOR:-}" ]] && use_color=0
[[ -t 1 ]] || use_color=0
if [[ "$use_color" -eq 1 ]]; then
  AMBER=$'\033[1;38;2;255;191;71m'; BLUE=$'\033[38;2;76;134;255m'
  TEXT=$'\033[38;2;237;242;255m';   DIM=$'\033[38;2;169;180;204m'
  GREEN=$'\033[38;2;51;209;122m';   RED=$'\033[38;2;246;97;81m'
  RESET=$'\033[0m'
else
  AMBER=""; BLUE=""; TEXT=""; DIM=""; GREEN=""; RED=""; RESET=""
fi

# ---- helpers ----------------------------------------------------------------
# Best-effort version string: non-interactive, never hangs (EOF on stdin + timeout).
_ver() {
  local bin="$1" v flag
  for flag in --version -V; do
    v="$(timeout 5 "$bin" "$flag" </dev/null 2>/dev/null | head -1 || true)"
    [[ -n "$v" ]] && break
  done
  [[ "${#v}" -gt 48 ]] && v="${v:0:47}..."
  printf '%s' "$v"
}

# _have <bin>... -> prints the first binary found on PATH (or nothing).
_have() {
  local b
  for b in "$@"; do
    if command -v "$b" >/dev/null 2>&1; then printf '%s' "$b"; return 0; fi
  done
  return 1
}

# Parse the user extras file -> one "label|bin[,altbins]|class" record per line.
# Tokens: a bare ":tui"/":util" sets the class (default util); the rest are label + bins.
_read_extras() {
  [[ -f "$EXTRAS_FILE" ]] || return 0
  local line cls i
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    # shellcheck disable=SC2206  # word-split into fields on purpose
    local -a f=($line) g=()
    cls="util"
    for i in "${f[@]}"; do
      case "$i" in
        :tui|:util) cls="${i#:}" ;;
        *) g+=("$i") ;;
      esac
    done
    [[ "${#g[@]}" -eq 0 ]] && continue
    if [[ "${#g[@]}" -eq 1 ]]; then
      printf '%s|%s|%s\n' "${g[0]}" "${g[0]}" "$cls"
    else
      printf '%s|%s|%s\n' "${g[0]}" "$(IFS=,; printf '%s' "${g[*]:1}")" "$cls"
    fi
  done < "$EXTRAS_FILE"
}

_hdr() {
  if [[ "$fmt" == md ]]; then printf '\n## %s\n' "$1"
  else printf '\n%s== %s ==%s\n' "$AMBER" "$1" "$RESET"; fi
}

# Row that ALWAYS shows status (present + absent). Args: label bin [altbin...]
_row_status() {
  local label="$1"; shift; local found v
  if found="$(_have "$@")"; then
    v="$(_ver "$found")"
    if [[ "$fmt" == md ]]; then printf -- '- **%s** %s\n' "$label" "${v:-present}"
    else printf '  %s✓%s %s%-11s%s %s%s%s\n' "$GREEN" "$RESET" "$TEXT" "$label" "$RESET" "$DIM" "${v:-present}" "$RESET"; fi
  else
    if [[ "$fmt" == md ]]; then printf -- '- **%s** _not installed_\n' "$label"
    else printf '  %s✗ %-11s not installed%s\n' "$RED" "$label" "$RESET"; fi
  fi
}

# Row that prints ONLY when present. Args: label bin [altbin...]
_row_present() {
  local label="$1"; shift; local found v
  if found="$(_have "$@")"; then
    v="$(_ver "$found")"
    if [[ "$fmt" == md ]]; then printf -- '- **%s** %s\n' "$label" "${v:-present}"
    else printf '  %s✓%s %s%-11s%s %s%s%s\n' "$GREEN" "$RESET" "$TEXT" "$label" "$RESET" "$DIM" "${v:-present}" "$RESET"; fi
  fi
}

# md/ansi key→value line for shortcuts (key padded in ansi).
_kv() {
  if [[ "$fmt" == md ]]; then printf -- '- **%s** — %s\n' "$1" "$2"
  else printf '  %s%-14s%s %s%s%s\n' "$BLUE" "$1" "$RESET" "$TEXT" "$2" "$RESET"; fi
}
_note() {
  if [[ "$fmt" == md ]]; then printf -- '- _%s_\n' "$1"
  else printf '  %s%s%s\n' "$DIM" "$1" "$RESET"; fi
}

# ---- sections ---------------------------------------------------------------
sec_agents() {
  _hdr "AI coding agents"
  local a
  for a in $_AGENTS; do _row_status "$a" "$a"; done
}

sec_tools() {
  _hdr "CLI / TUI tools"
  local rec label bins cls
  for rec in "${_TOOLS[@]}"; do
    IFS='|' read -r label bins cls <<<"$rec"
    IFS=',' read -r -a bb <<<"$bins"
    _row_present "$label" "${bb[@]}"
  done
  while IFS='|' read -r label bins cls; do
    IFS=',' read -r -a bb <<<"$bins"
    _row_present "$label" "${bb[@]}"
  done < <(_read_extras)
  _note "(only installed tools are shown; declare extras in ${EXTRAS_FILE/#$HOME/\~})"
}

# Static cheatsheet — KEEP IN SYNC with dotfiles/tmux/tmux.conf if you change binds.
sec_shortcuts() {
  _hdr "Key shortcuts — tmux (prefix C-a)"
  _kv "C-a 1/2/3/4" "layouts: 2-col · 3-col · main-vertical · 2x2 grid"
  _kv "C-a | / -"   "split vertical / horizontal (path-aware)"
  _kv "C-a h/j/k/l" "move between panes (H/J/K/L resize)"
  _kv "C-a c / w"   "new window / list windows"
  _kv "C-a d / r"   "detach session / reload config"
  _kv "mouse"       "on — click panes/windows, drag borders"
  _note "(tmux is launched manually; GNOME Terminal tabs: Ctrl+Shift+T, Ctrl+PgUp/PgDn)"
  if [[ "$fmt" == md ]]; then printf -- '- **yazi open** — Enter / o → micro · Shift+E → vim\n'
  else printf '  %syazi open%s    %s%s%s\n' "$BLUE" "$RESET" "$TEXT" "Enter / o → micro · Shift+E → vim" "$RESET"; fi
}

sec_templates() {
  _hdr "Nautilus templates (~/Templates → right-click ▸ New Document)"
  local tdir="$HOME/Templates" f any=0
  if [[ -d "$tdir" ]]; then
    for f in "$tdir"/*; do
      [[ -e "$f" ]] || continue
      if [[ "$fmt" == md ]]; then printf -- '- %s\n' "$(basename "$f")"
      else printf '  %s•%s %s%s%s\n' "$BLUE" "$RESET" "$TEXT" "$(basename "$f")" "$RESET"; fi
      any=1
    done
  fi
  [[ "$any" -eq 0 ]] && _note "(no templates in $tdir)"
}

sec_paths() {
  _hdr "Config & paths"
  if [[ "$fmt" == md ]]; then
    printf -- '- **Terminal** — GNOME Terminal, profile mahg-dark (always dark), white block cursor\n'
    printf -- '- **Multiplex** — tmux (prefix C-a, manual) for splits/sessions; GNOME Terminal tabs\n'
    printf -- '- **Editors** — micro (default, EDITOR/VISUAL) · vim (heavy lifting) · gnome-text-editor\n'
    printf -- '- **Browser** — Firefox (mahg theme, signed .xpi)\n'
    printf -- '- **Prompt** — Starship: full path, [ branch ] amber, ╰─❯ blue connector\n'
    printf -- '- **Brand** — navy #070b16 · blue #4c86ff · amber #ffbf47 · text #edf2ff (palette in lnx-gui-ide)\n'
    printf -- '- **Repos** — ~/github/mahernandezg/lnx-cli-tui-ide · ~/github/mahg-es/araya (+ lnx-gui-ide)\n'
    printf -- '- **Agent data** — pi ~/.pi · claude ~/.local/share/claude + ~/.claude · codex ~/.codex · agy ~/.gemini/antigravity-cli · grok ~/.grok · copilot ~/.config\n'
  else
    printf '  %sTerminal%s  GNOME Terminal — profile %smahg-dark%s (always dark), white block cursor\n' "$BLUE" "$RESET" "$AMBER" "$RESET"
    printf '  %sMultiplex%s tmux (prefix C-a, manual) for splits/sessions; GNOME Terminal tabs\n' "$BLUE" "$RESET"
    printf '  %sEditors%s   micro (default editor, EDITOR/VISUAL) · vim (heavy lifting) · gnome-text-editor\n' "$BLUE" "$RESET"
    printf '  %sBrowser%s   Firefox (mahg theme, signed .xpi)\n' "$BLUE" "$RESET"
    printf '  %sPrompt%s    Starship — full path, [ branch ] amber, ╰─❯ blue connector\n' "$BLUE" "$RESET"
    printf '  %sBrand%s     navy #070b16 · blue #4c86ff · amber #ffbf47 · text #edf2ff\n' "$BLUE" "$RESET"
    printf '             (palette config: mahg-brand-palette.conf, in the lnx-gui-ide repo)\n'
    printf '  %sRepos%s     ~/github/mahernandezg/lnx-cli-tui-ide · ~/github/mahg-es/araya (+ lnx-gui-ide)\n' "$BLUE" "$RESET"
    printf '  %sAgent data%s pi ~/.pi · claude ~/.local/share/claude + ~/.claude · codex ~/.codex\n' "$BLUE" "$RESET"
    printf '             agy ~/.gemini/antigravity-cli (+keyring) · grok ~/.grok · copilot ~/.config\n'
  fi
}

sec_footer() {
  if [[ "$fmt" == md ]]; then
    printf -- '\n_mahg-help [agents|tools|shortcuts|templates|paths] · --format md · --list tools_\n'
  else
    printf '\n%sTip:%s mahg-help [agents|tools|shortcuts|templates|paths] · mahg-help --version\n' "$DIM" "$RESET"
    printf '%s     the interactive TUI launcher arrives in the next version.%s\n' "$DIM" "$RESET"
  fi
}

# ---- --list mode (parseable; no headers/colour/version) ---------------------
_list_tools() {
  local recs=() rec label bins cls found
  mapfile -t recs < <(printf '%s\n' "${_TOOLS[@]}"; _read_extras)
  for rec in "${recs[@]}"; do
    IFS='|' read -r label bins cls <<<"$rec"
    IFS=',' read -r -a bb <<<"$bins"
    if found="$(_have "${bb[@]}")"; then printf '%s\t%s\n' "$found" "$cls"; fi
  done
}
_list_agents() {
  local a
  for a in $_AGENTS; do command -v "$a" >/dev/null 2>&1 && printf '%s\ttui\n' "$a"; done
}

if [[ -n "$list" ]]; then
  case "$list" in tools) _list_tools ;; agents) _list_agents ;; esac
  exit 0
fi

# ---- render -----------------------------------------------------------------
if [[ "$fmt" == md ]]; then printf '# mahg-help — your environment at a glance\n'
else printf '%smahg-help%s %s— your environment at a glance%s\n' "$AMBER" "$RESET" "$DIM" "$RESET"; fi
case "$section" in
  agents)    sec_agents ;;
  tools)     sec_tools ;;
  shortcuts) sec_shortcuts ;;
  templates) sec_templates ;;
  paths)     sec_paths ;;
  all)       sec_agents; sec_tools; sec_shortcuts; sec_templates; sec_paths; sec_footer ;;
esac
